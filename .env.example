# Tezos RPC (Shadownet; Ghostnet is being discontinued)
VITE_RPC_URL=https://rpc.shadownet.teztnets.com
VITE_NETWORK=shadownet

# App name shown in wallet connection prompt
VITE_APP_NAME=Tezos Launchpad

# Optional: app icon URL (e.g. for wallet pairing)
# VITE_APP_ICON=https://tezos.com/favicon.ico

# Optional: demo contract address (KT1...) for "Read contract storage"
# VITE_DEMO_CONTRACT=KT1...

# GitHub repo for "Add a tutorial" link (issues/discussions for contributing tutorials)
# VITE_GITHUB_REPO=https://github.com/panagot/Tezos-From-zero-to-dApp
